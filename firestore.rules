rules_version = '2';

// Tethra security model
// - A person can only read/write their own data.
// - Private notes never leave the owner's document.
// - A shared space is readable/writable only by its two participants.
// - Sharing happens by copying ONLY shareable fields into the space (done in app code),
//   so a partner never gains read access to another person's private map.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    // Profile + onboarding + privacy preferences
    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    // One document per user. Holds the full comfort map incl. private notes.
    match /comfortMaps/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Physical Intimacy Comfort — the most sensitive data in the app.
    // Owner-only, full stop. No partner can read this document.
    // When partner sharing is built, exposure happens the same way as the
    // rest of the app: the app copies ONLY items whose visibility == "partner"
    // into a sharedSpace doc. The raw intimacyMaps document is never shared.
    match /intimacyMaps/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Relationship blueprint (one doc per user)
    match /blueprints/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Private reflections (one doc per user, list inside)
    match /reflections/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Consent check-ins
    match /checkIns/{docId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // Two-party shared spaces
    // Two-party shared spaces. The document id IS the invite code, so knowing the
    // code is what grants the ability to read a still-open space and join it once.
    // Raw comfort/intimacy maps are never shared here — only the snapshot each
    // person copies in (their own chosen fields).
    match /sharedSpaces/{code} {
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.invitedUserId == null;

      allow read: if signedIn() && (
        resource.data.createdBy == request.auth.uid
        || resource.data.invitedUserId == request.auth.uid
        || (resource.data.status == "pending" && resource.data.invitedUserId == null)
      );

      allow update: if signedIn() && (
        resource.data.createdBy == request.auth.uid
        || resource.data.invitedUserId == request.auth.uid
        || (
          resource.data.status == "pending"
          && resource.data.invitedUserId == null
          && request.resource.data.invitedUserId == request.auth.uid
          && request.resource.data.createdBy == resource.data.createdBy
        )
      );

      allow delete: if signedIn() && resource.data.createdBy == request.auth.uid;
    }
  }
}
